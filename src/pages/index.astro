---
import Layout from "../layouts/Layout.astro";
import Main from "../components/Main.astro";
import ProjectList from "../components/ProjectList.astro";
import TechnologiesList from "../components/TechnologiesList.astro";
import H2 from "../components/H2.astro";
import { Row } from "../components/React/Row";
import { AnimationMove } from "../components/React/AnimationMove";
---

<Layout title="Mi portafolio">
  <div
    class="pointer-events-none inset-0 z-30 transition duration-300 lg:absolute follower"
  >
  </div>
  <section
    class="flex-col sm:flex gap-5 relative min-h-screen pointer-events-none z-20 overflow-hidden"
  >
    <Main className="flex flex-col justify-center  items-center min-h-screen">
      <div class="flex flex-col justify-center w-full">
        <div class="overflow-hidden">
          <AnimationMove
            client:visible
            initial={{ y: "100%" }}
            duration={1}
            viewport={true}
          >
            <h1
              class="text-rainbow text-3xl sm:text-6xl md:text-8xl uppercase text-zinc-95 font-bold"
            >
              DESARROLLADOR FRONTEND
            </h1>
          </AnimationMove>
        </div>
        <AnimationMove
          client:visible
          initial={{ x: "-100%" }}
          duration={1}
          delay={0.8}
          viewport={true}
          className="flex items-center text-xs sm:text-sm md:text-base text-yellow-950 uppercase mt-3"
        >
          <svg class="h-5 w-5 mr-1" viewBox="0 0 24 24"
            ><path
              fill="currentColor"
              d="M16.175 13H4v-2h12.175l-5.6-5.6L12 4l8 8l-8 8l-1.425-1.4l5.6-5.6Z"
            ></path></svg
          >Creador de experiencias web con React
        </AnimationMove>
      </div>
    </Main>

    <div
      class="absolute bottom-0 flex items-center w-full justify-center flex-col"
    >
      <AnimationMove
        client:visible
        initial={{ y: "100%" }}
        duration={1}
        delay={1.6}
        viewport={true}
        className="flex flex-col pb-2 items-center"
      >
        <Row client:visible />
        <div class="text-yellow-800 text-xs md:text-base">SCROLL</div>
      </AnimationMove>

      <div
        class="absolute right-0 bottom-0 flex flex-col justify-end items-end"
      >
        <AnimationMove
          client:visible
          initial={{ y: "100%" }}
          final={{ y: "10%" }}
          duration={1}
          delay={1.5}
          viewport={true}
        >
          <img
            src="/images/juan2.png"
            class="object-cover h-auto w-72 grayscale hover:grayscale-0 mx-3"
          />
        </AnimationMove>
      </div>
    </div>
  </section>

  <section class="min-h-screen bg-stone-800 flex justify-center items-center">
    <Main className="text-4xl text-stone-300  font-medium">
      <AnimationMove
        client:visible
        initial={{ opacity: 0, x: "-100%" }}
        duration={1.4}
      >
        <p>
          Estudiante de escuela técnica en programación<span
            class="text-rainbow">.</span
          >
        </p>
      </AnimationMove>
      <AnimationMove
        client:visible
        initial={{ opacity: 0, x: "-100%" }}
        duration={1.4}
        delay={0.1}
      >
        <p>
          Cursando ingreso a ingeniería en sistemas<span class="text-rainbow"
            >.</span
          >
        </p>
      </AnimationMove>
      <AnimationMove
        client:visible
        initial={{ opacity: 0, x: "-100%" }}
        duration={1.4}
        delay={0.2}
      >
        <p>
          Mi curiosidad por los videojuegos y mi pasión por el diseño me llevo a
          estudiar desarrollo web de forma autodidacta desde hace mas de 3 años<span
            class="text-rainbow">.</span
          >
        </p>
      </AnimationMove>
      <AnimationMove
        client:visible
        initial={{ opacity: 0, x: "-100%" }}
        duration={1.4}
        delay={0.3}
      >
        <p>
          Disfruto trabajando en equipo y siempre estoy dispuesto a aprender
          cosas nuevas<span class="text-rainbow">.</span>
        </p>
      </AnimationMove>
    </Main>
  </section>

  <section>
    <Main>
      <H2 text="Projectos" id="projects" />
      <ProjectList />
    </Main>
  </section>
  <section class="flex gap-20">
    <div class="flex items-start">
      <H2 text="Educacion" id="educacion" margin={false} />
    </div>
    <div class="w-full flex flex-col mt-3">
      <div class="flex justify-between">
        <div>
          <div class="mb-2 flex justify-between items-center">
            <p class="dark:text-stone-200 font-bold">
              ESCUELA TECNICA Nº2 ING. FELIPE SENILLOSA
            </p>
            <span class="dark:text-stone-300 min-w-fit">2020 - 2023</span>
          </div>
          <p class="text-rainbow text-base">
            Tecnicatura, Programación informática, aplicaciones específicas
          </p>
          <ul class="dark:text-stone-300 mt-5 ml-1 text-base">
            <li>
              - Aprendi a planificar, diseñar y desarrollar un proyecto web,
              creando TRYNING, una aplicación de gestion de rutinas<span
                class="text-rainbow">.</span
              >
            </li>
            <li>
              - Diseñe el prototipo de alta y baja fidelidad con la herramienta
              figma<span class="text-rainbow">.</span>
            </li>
            <li>
              - Desarrolle el frontend y backend, utilizando Vite, React Js,
              Tailwind, Firebase, Node JS, Express, phpMyAdmin<span
                class="text-rainbow">.</span
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  <section>
    <H2 text="Tecnologias" id="tecnologias" />
    <TechnologiesList />
  </section>
</Layout>

<style>
  h1 {
    color: #eee236;
  }
  @keyframes gradient {
    0% {
      background-position: 0% 0%;
    }

    50% {
      background-position: 100% 0%;
    }
    100% {
      background-position: 0% 0%;
    }
  }
</style>

<script>
  let follower = document.querySelector(".follower");

  function followMouse(event: MouseEvent) {
    const { clientX, clientY } = event;
    const bodyX = clientX - document.body.getBoundingClientRect().left;
    const bodyY = clientY - document.body.getBoundingClientRect().top;

    // Aplica el fondo con coordenadas relativas al cuerpo
    follower!.style.background = `radial-gradient(600px at ${bodyX}px ${bodyY}px,  #eee23644, transparent 80%)`;
  }

  document.addEventListener("mousemove", followMouse);
</script>
