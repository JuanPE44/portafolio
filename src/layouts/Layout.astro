---
import { ViewTransitions } from "astro:transitions";

import Header from "../components/Header.astro";
import Follower from "../components/Follower.astro";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <ViewTransitions />
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="bg-stone-900 overflow-y-auto overflow-x-hidden pointer-events-auto"
    transition:animate="fade"
  >
    <Follower />
    <Header />
    <slot />

    <style is:global>
      :root {
        --color-1: #51c6f4;
        --color-2: #9e1ed1;
        --color-3: #f451ec;
      }
      html,
      body {
        scroll-behavior: smooth;
        backdrop-filter: blur(100px);
      }

      ::-webkit-scrollbar {
        width: 10px;
      }

      /* Track */
      ::-webkit-scrollbar-track {
        background: #f1f1f1;
      }

      /* Handle */
      ::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 5px;
      }

      /* Handle on hover */
      ::-webkit-scrollbar-thumb:hover {
        background: #555;
      }

      .text-rainbow {
        background: linear-gradient(
          89.81deg,
          var(--color-1),
          var(--color-2),
          var(--color-3)
        );
        fill: linear-gradient(
          89.81deg,
          var(--color-1),
          var(--color-2),
          var(--color-3)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-fill-color: transparent;
        background-size: 120%;
        animation: gradientText 10s ease infinite;
      }

      @keyframes gradientText {
        0% {
          background-position: left;
        }
        100% {
          background-position: right;
        }
      }

      .bg-dotted {
        position: relative;
        background-image: radial-gradient(#444 1px, transparent 1px);
        background-size: 5px 5px;
        background-position:
          0 0,
          10px 10px;
      }

      .bg-gradient::before {
        content: " ";
        position: absolute;
        width: 100%;
        height: 100%;
        background-image: url("/images/bg-degrade.png");
        background-size: cover;
        background-repeat: no-repeat;
        background-position: right top;
        animation: fondo-inicio 6s ease;
        pointer-events: none;
      }

      @media (max-width: 576px) {
        .bg::before {
          opacity: 0.6;
        }
      }

      @keyframes fondo-inicio {
        0% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }
    </style>
  </body>
</html>
