---
import { ButtonTheme } from "./ButtonTheme.jsx";
---

<header class="absolute top-0 w-full z-50">
  <section
    class="px-20 py-10 max-sm:px-5 max-w-5xl m-auto w-full flex items-center justify-between"
  >
    <a
      class="text-xl text-zinc-950 dark:text-white font-bold dark:font-semibold font-outfit"
      >JP</a
    >
    <nav>
      <ul class="flex items-center gap-4">
        <li>
          <a
            href="#projects"
            class="text-lg text-zinc-950 font-semibold dark:text-white"
            >Proyectos</a
          >
        </li>
        <li class="ml-6 flex justify-center items-center">
          <ButtonTheme client:visible />
        </li>
      </ul>
    </nav>
  </section>
</header>
