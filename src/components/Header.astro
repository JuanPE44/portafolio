        <h2 class="text-base text-stone-100">
          Juan Peñalba <span class="text-3xl text-rainbow">.</span>
        </h2>
      </AnimationMove>
    </div>
    <div class="overflow-hidden flex items-end text-sm">
      <AnimationMove
