---
import { AnimationMove } from "./React/AnimationMove";
---

<header class="relative top-0 w-full z-50">
  <section
    class="px-20 py-10 max-sm:px-5 max-w-7xl m-auto w-full flex items-center justify-between"
  >
    <div class="overflow-hidden w-full">
      <AnimationMove
        client:visible
        initial={{ y: "-100%", opacity: 0 }}
        ease="easeOut"
        duration={2}
        delay={2.2}
      >
        <h2
          class="text-base sm:text-2xl font-semibold dark:text-stone-200 text-stone-600 mb-2"
        >
          Juan Peñalba
        </h2>
      </AnimationMove>
    </div>
  </section>
</header>
